flowchart TD
    %% Human-readable overview, not canonical evidence.
    %% Registry-derived projection: rendered/ecosystem-registry-map.mmd
    U[Alexander / Mensch<br/>Sinn, Freigabe, Prioritaet, Abbruch]

    subgraph Sense[Orientierung und Entscheidung]
        CAB[Cabinet<br/>Sinn, Evidenz, Priorisierung, Lernen]
        MAP[Ecosystem Map v0<br/>Graph, Ledger, Rollen]
    end

    subgraph Work[Operative Taktung]
        BUR[Bureau<br/>Queue, Delegation, Rueckmeldung]
        GRAB[Grabowski<br/>Operator, Repo-Arbeit, Review-Gates]
        AG[Agenten<br/>Codex, Claude, Jules, lokal]
    end

    subgraph Context[Kontext und Belege]
        RB[RepoBrief / Lenskit<br/>zitierfaehige Kontextansicht]
        VIBE[Vibe-Lab<br/>Methoden- und Evidence-Lab]
        CHR[Chronik<br/>Event-Trace]
        STB[Steuerboard<br/>Repo-State-Signal]
    end

    subgraph Reality[Harte Realitaetspruefung]
        GH[GitHub<br/>PRs, Issues, Reviews]
        CI[CI / Checks<br/>Tests, Gates, Reviews]
        RT[Runtime<br/>heim-pc, heimserver]
        C[Contracts / Schemas / Tests]
    end

    subgraph Surfaces[Ansicht und Nutzung]
        SCH[Schauwerk<br/>visuelle Arbeitsflaeche]
        INF[Infra<br/>Cockpit, Host, Runbooks]
        WW[Weltgewebe<br/>Produkt- und Domaenenkern]
    end

    U --> CAB
    CAB --> MAP
    MAP --> CAB
    CAB -->|approved candidates| BUR
    BUR -->|scope and evidence contract| GRAB
    GRAB --> AG
    AG -->|patch, review, finding| GRAB
    GRAB -->|run reports, open risks| BUR
    BUR -->|feedback| CAB

    RB --> CAB
    VIBE --> CAB
    CHR --> CAB
    STB --> CAB

    GRAB --> GH
    GH --> CI
    CI --> GRAB
    C --> CI
    INF --> RT
    RT --> CAB
    WW --> GH
    SCH --> MAP

    classDef canon stroke-width:2px;
    class CAB,MAP canon;
