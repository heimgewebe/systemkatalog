{
  "schema_version": 1,
  "id": "cabinet_maintenance_radar_v0",
  "status": "draft",
  "updated_at": "2026-07-09",
  "canonical_doc": "docs/blueprints/cabinet-maintenance-radar-v0.md",
  "role_boundary_doc": "docs/blueprints/cabinet-role-boundary-v1.md",
  "mode": "read_only_quality_radar",
  "role_decision": {
    "decision": "keep_cabinet_as_semantic_evidence_and_prioritization_layer",
    "replacement_decision": "do_not_replace_with_a_single_general_purpose_tool",
    "cabinet_canon_for": [
      "meaning",
      "evidence_surface",
      "claim_boundaries",
      "prioritization_context",
      "map_semantics",
      "read_only_coherence_radar",
      "maintenance_findings",
      "proposal_only_handoff_candidates"
    ],
    "cabinet_not_canon_for": [
      "task_queue",
      "scheduler",
      "operator_execution",
      "merge_or_push_decision",
      "runtime_state",
      "live_dashboard",
      "service_catalog_ui",
      "github_ci_runtime_truth",
      "repobrief_lenskit_dump_generation"
    ]
  },
  "default_tool_routing": {
    "task_queue": "bureau",
    "task_cadence_receipts": "bureau",
    "repo_execution": "grabowski_operator",
    "context_dumps": "repobrief_lenskit",
    "live_display": "leitstand_or_schauwerk",
    "git_pr_review_truth": "github",
    "ci_truth": "ci",
    "runtime_truth": "runtime_systemd_logs_healthchecks",
    "learning_feedback": "heimlern_after_review"
  },
  "replacement_gate": {
    "cabinet_replacement_allowed": false,
    "minimum_conditions": [
      "versioned_claims_evidence_expiry_primary_sources_and_organ_roles",
      "separates_radar_queue_operator_runtime_and_release_authority",
      "controllable_for_local_and_private_sources",
      "machine_checkable_drift_and_non_claims",
      "no_new_shadow_authority"
    ]
  },
  "repobrief_lenskit_dump_generation": "external_only",
  "cabinet_generates_repobrief_lenskit_dumps": false,
  "allowed_scan_classes": [
    "consistency",
    "structural_error",
    "freshness",
    "authority_order",
    "handoff_readiness",
    "effect_closure",
    "external_artifact_surface",
    "learning_feedback"
  ],
  "required_finding_fields": [
    "id",
    "scan_id",
    "rule_id",
    "subject",
    "finding_type",
    "severity",
    "evidence",
    "confidence",
    "status",
    "responsible_organ",
    "next_action",
    "created_at"
  ],
  "required_outcome_fields": [
    "finding_id",
    "outcome",
    "evidence",
    "closed_at",
    "reviewer",
    "learning_allowed"
  ],
  "allowed_outputs": [
    "cabinet.scan_finding.v1",
    "cabinet.maintenance_report.v1",
    "cabinet.maintenance_outcome.v1",
    "cabinet.handoff_candidate.v1",
    "heimlern.policy_adjustment.proposed.v1"
  ],
  "handoff": {
    "bureau_mode": "proposal_only",
    "grabowski_mode": "after_task_or_operator_release",
    "requires_human_review": true,
    "task_creation_allowed": false,
    "dispatch_allowed": false,
    "queue_mutation_allowed": false,
    "runtime_mutation_allowed": false
  },
  "heimlern_bridge": {
    "status": "planned_after_contract_repair",
    "input_contracts": [
      "cabinet.maintenance_outcome.v1",
      "decision.outcome.v1"
    ],
    "output_contracts": [
      "policy.weight_adjustment.proposed.v1",
      "cabinet.scan_rule_weight_adjustment.proposed.v1",
      "cabinet.routing_policy_adjustment.proposed.v1"
    ],
    "direct_policy_application_allowed": false,
    "minimum_outcomes_per_rule": 20,
    "minimum_confidence": 0.6
  },
  "prohibited_effects": [
    "repobrief_or_lenskit_dump_generation",
    "automatic_bureau_task_creation",
    "automatic_grabowski_delegation",
    "merge_or_push_action",
    "runtime_mutation",
    "cleanup_action",
    "authority_inference_from_map",
    "direct_policy_weight_application",
    "dashboard_authority_inference",
    "service_catalog_authority_inference",
    "task_queue_authority_inference"
  ],
  "primary_sources": {
    "git_pr_review": "GitHub",
    "ci_signal": "CI",
    "runtime_signal": "Runtime/systemd/logs/healthchecks",
    "contract_invariant": "contracts/schemas/tests",
    "priority_release_stop": "human_decision",
    "context_dump": "external_repobrief_lenskit_artifact",
    "learning_feedback": "heimlern_proposal_review"
  },
  "organ_roles": {
    "cabinet": "read_only_coherence_radar_and_candidate_prioritizer",
    "bureau": "task_cadence_receipt_and_handoff_owner",
    "grabowski_operator": "execution_after_task_or_operator_release",
    "repobrief_lenskit": "external_context_dump_producer_and_citable_context_surface",
    "heimlern": "retrospective_outcome_analysis_and_proposal_only_policy_adjustments",
    "chronik": "event_continuity_and_decision_trace",
    "leitstand_schauwerk": "display_and_visualization_consumer_not_canon",
    "github_ci_runtime": "primary_truth_for_pr_check_and_runtime_state",
    "external_agents": "proposal_and_review_not_authority"
  },
  "does_not_establish": [
    "task_approval",
    "merge_readiness",
    "runtime_correctness",
    "claim_truth",
    "bureau_import_implemented",
    "autonomous_dispatch",
    "policy_change_approval",
    "dump_freshness_truth",
    "service_catalog_truth",
    "dashboard_truth",
    "tool_replacement_approval"
  ]
}
