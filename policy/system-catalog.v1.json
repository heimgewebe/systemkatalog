{
  "schemaVersion": 1,
  "kind": "heimgewebe_system_catalog_policy",
  "role": "app-independent system catalog",
  "answers": [
    "which_systems_exist",
    "what_is_each_systems_purpose",
    "which_truth_source_owns_each_domain",
    "which_stable_relationships_exist",
    "where_are_the_entrypoints"
  ],
  "doesNotAnswer": [
    "task_priority",
    "task_state",
    "runtime_health",
    "merge_readiness",
    "active_execution",
    "agent_dispatch",
    "scheduler_state"
  ],
  "currentCanonicalInputs": [
    "registry/ecosystem/nodes.json",
    "registry/ecosystem/edges.json",
    "registry/ecosystem/claims.jsonl",
    "registry/ecosystem/authority-matrix.v1.json"
  ],
  "canonicalReadableProjection": "rendered/system-catalog.md",
  "publicProjection": {
    "excludedKinds": [
      "runtime",
      "agent"
    ],
    "reason": "Concrete runtime identities and topology remain in private operator evidence; the public catalog points to the runtime truth domain without duplicating host inventory."
  },
  "targetFormat": {
    "schema": "catalog/system-catalog.schema.v1.json",
    "example": "catalog/system-catalog.example.v1.json",
    "exampleIsCanonical": false,
    "requiredSystemFields": [
      "id",
      "name",
      "type",
      "purpose",
      "notResponsibleFor",
      "truthOwnership",
      "entrypoints"
    ]
  },
  "entrypoints": [
    {
      "id": "heimgewebe_katalog",
      "label": "Heimgewebe-Systemkatalog",
      "target": "README.md"
    },
    {
      "id": "bureau",
      "label": "Bureau",
      "target": "https://github.com/heimgewebe/bureau"
    },
    {
      "id": "grabowski",
      "label": "Grabowski",
      "target": "https://github.com/heimgewebe/grabowski"
    },
    {
      "id": "repobrief_lenskit",
      "label": "RepoBrief / Lenskit",
      "target": "https://github.com/heimgewebe/lenskit"
    },
    {
      "id": "leitstand",
      "label": "Leitstand",
      "target": "https://github.com/heimgewebe/leitstand"
    },
    {
      "id": "github",
      "label": "GitHub",
      "target": "https://github.com/heimgewebe"
    }
  ],
  "externalCabinetApp": {
