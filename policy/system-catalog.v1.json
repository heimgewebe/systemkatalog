    "canonical": false,
    "runtimeAuthoritative": false,
    "shutdownAuthorized": true,
    "activeRuntime": false,
    "replacement": "heimgewebe-systemkatalog.service"
  },
  "prohibitedOperationalFields": [
    "status",
    "priority",
    "taskState",
    "runtimeHealth",
    "mergeReadiness",
    "activeExecution",
    "agentDispatch",
    "schedulerState",
    "confidence",
    "expiresAt",
    "nextAction",
    "responsibleOrgan",
    "host",
    "unit",
    "listener",
    "port"
  ],
  "doesNotEstablish": [
    "runtime_health",
    "task_eligibility",
    "merge_readiness",
    "claim_truth",
    "live_runtime_health"
  ],
  "contractState": "active",
  "canonicalAuthorityMatrix": "registry/ecosystem/authority-matrix.v1.json",
  "canonicalGeneratedMap": "rendered/ecosystem-registry-map.mmd",
  "canonicalProjectionPolicy": "policy/ecosystem-map-view.v1.json",
  "stableRelationClasses": [
    "stable",
    "bounded",
    "related"
  ],
  "maintainedCatalogSurfaces": [
