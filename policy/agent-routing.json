{
  "schema": "cabinet.agent-routing-policy.v1",
  "default_posture": "least_coupled_review_first",
  "data_classes": {
    "public_repo_diff": {
      "description": "Repository diffs and source files that may be shared for review after operator judgement.",
      "external_allowed": true
    },
    "local_runtime": {
      "description": "Local filesystem, runtime state, service state, and operational receipts.",
      "external_allowed": false
    },
    "private_context": {
      "description": "Personal context, credentials, private notes, or unredacted transcripts.",
      "external_allowed": false
    },
    "architecture_summary": {
      "description": "Summaries, briefs, decision matrices, and sanitized system design notes.",
      "external_allowed": true
    }
  },
  "agents": {
    "grabowski": {
      "role": "local_execution",
      "may_mutate": true,
      "requires_local_evidence": true
    },
    "chatgpt_codex": {
      "role": "implementation_and_review",
      "may_mutate": false,
      "requires_local_evidence": true
    },
    "claude": {
      "role": "architecture_and_safety_review",
      "may_mutate": false,
      "requires_local_evidence": true
    },
    "gemini": {
      "role": "broad_analysis_and_second_opinion",
      "may_mutate": false,
      "requires_local_evidence": true
    },
    "bureau": {
      "role": "coordination_and_receipts",
      "may_mutate": false,
      "requires_local_evidence": true
    },
    "cabinet": {
      "role": "meaning_and_decision_layer",
      "may_mutate": false,
      "requires_local_evidence": true
    }
  },
  "routes": [
    {
      "id": "small_docs_slice",
      "task_class": "small_docs_slice",
      "data_class": "architecture_summary",
      "default_agents": ["grabowski", "chatgpt_codex"],
      "second_review": "optional",
      "evidence": ["pr", "checks"],
      "stop": "unexpected_scope_growth"
    },
    {
      "id": "code_slice",
      "task_class": "code_slice",
      "data_class": "public_repo_diff",
      "default_agents": ["grabowski", "chatgpt_codex"],
      "second_review": "required_when_complex_or_risky",
      "evidence": ["diff", "tests", "pr"],
      "stop": "tests_missing_or_review_blocking"
    },
    {
      "id": "architecture_decision",
      "task_class": "architecture_decision",
      "data_class": "architecture_summary",
      "default_agents": ["cabinet", "chatgpt_codex"],
      "second_review": "claude_or_gemini_when_risky",
      "evidence": ["decision_brief", "open_questions"],
      "stop": "decision_requires_unavailable_facts"
    },
    {
      "id": "repo_status_drift",
      "task_class": "repo_status_drift",
      "data_class": "local_runtime",
      "default_agents": ["grabowski"],
      "second_review": "cabinet_summary_optional",
      "evidence": ["steuerboard_report", "git_status"],
      "stop": "dirty_or_diverged_checkout_without_owner"
    },
    {
      "id": "worktree_lifecycle",
      "task_class": "worktree_lifecycle",
      "data_class": "local_runtime",
      "default_agents": ["grabowski"],
      "second_review": "required_when_destructive",
      "evidence": ["preview", "recovery_reference", "apply_receipt"],
      "stop": "recovery_path_missing"
    },
    {
      "id": "large_system_question",
      "task_class": "large_system_question",
      "data_class": "architecture_summary",
      "default_agents": ["cabinet", "chatgpt_codex"],
      "second_review": "claude_and_gemini_preferred",
      "evidence": ["synthesis", "known_gaps"],
      "stop": "summary_would_drive_unreviewed_mutation"
    }
  ],
  "global_rules": [
    "External agents do not mutate local repositories or runtimes directly.",
    "Local runtime evidence stays with Grabowski unless explicitly summarized.",
    "Every non-default route records why it was chosen.",
    "Complex or risky pull requests require self-review before merge."
  ]
}
