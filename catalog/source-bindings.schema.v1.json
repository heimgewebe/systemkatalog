{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://github.com/heimgewebe/systemkatalog/blob/main/catalog/source-bindings.schema.v1.json",
  "title": "Systemkatalog source bindings v1",
  "type": "object",
  "additionalProperties": false,
  "required": ["schemaVersion", "kind", "catalogRepository", "observedAt", "systems", "relations", "doesNotEstablish"],
  "properties": {
    "schemaVersion": {"const": 1},
    "kind": {"const": "system_catalog_source_bindings"},
    "catalogRepository": {"const": "heimgewebe/systemkatalog"},
    "observedAt": {"type": "string", "format": "date-time"},
    "systems": {"type": "array", "minItems": 1},
    "relations": {"type": "array"},
    "doesNotEstablish": {"type": "array", "minItems": 1, "items": {"type": "string", "minLength": 1}, "uniqueItems": true}
  }
}
