{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://heimgewebe.local/cabinet/schemas/operator-redundancy-audit.v1.schema.json",
  "title": "Operator Ecosystem Redundancy Audit v1",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schemaVersion",
    "kind",
    "observedAt",
    "scope",
    "evidenceRefs",
    "summary",
    "organs",
    "actions",
    "doesNotEstablish"
  ],
  "properties": {
    "schemaVersion": {
      "const": 1
    },
    "kind": {
      "const": "operator_ecosystem_redundancy_audit"
    },
    "observedAt": {
      "type": "string",
      "minLength": 1
    },
    "scope": {
      "type": "object"
    },
    "summary": {
      "type": "object"
    },
    "organs": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": [
          "id",
          "authority",
          "observedConsumers",
          "duplicateData",
          "manualMaintenance",
          "shutdown",
          "recommendation",
          "confidence",
          "evidenceClass"
        ],
        "properties": {
          "id": {
            "type": "string",
            "pattern": "^[a-z0-9_]+$"
          },
          "authority": {
            "type": "string",
            "minLength": 1
          },
          "observedConsumers": {
            "type": "array",
            "items": {
              "type": "string",
              "minLength": 1
            }
          },
          "duplicateData": {
            "type": "array",
            "items": {
              "type": "string",
              "minLength": 1
            }
          },
          "manualMaintenance": {
            "type": "object",
            "additionalProperties": false,
            "required": [
              "level",
              "drivers"
            ],
            "properties": {
              "level": {
                "type": "string",
                "minLength": 1
              },
              "drivers": {
                "type": "array",
                "minItems": 1,
                "items": {
                  "type": "string",
                  "minLength": 1
                }
              }
            }
          },
          "shutdown": {
            "type": "object",
            "additionalProperties": false,
            "required": [
              "class",
              "conditions",
              "partialShutdown"
            ],
            "properties": {
              "class": {
                "type": "string",
                "minLength": 1
              },
              "conditions": {
                "type": "array",
                "items": {
                  "type": "string",
                  "minLength": 1
                }
              },
              "partialShutdown": {
                "type": "string",
                "minLength": 1
              }
            }
          },
          "recommendation": {
            "type": "string",
            "minLength": 1
          },
          "confidence": {
            "type": "number",
            "minimum": 0,
            "maximum": 1
          },
          "evidenceClass": {
            "type": "array",
            "minItems": 1,
            "items": {
              "type": "string",
              "minLength": 1
            }
          }
        }
      }
    },
    "actions": {
      "type": "array",
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": [
          "priority",
          "id",
          "owner",
          "decision"
        ],
        "properties": {
          "priority": {
            "enum": [
              "P0",
              "P1",
              "P2",
              "P3"
            ]
          },
          "id": {
            "type": "string",
            "pattern": "^[a-z0-9-]+$"
          },
          "owner": {
            "type": "string",
            "minLength": 1
          },
          "decision": {
            "type": "string",
            "minLength": 1
          }
        }
      }
    },
    "doesNotEstablish": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "string",
        "minLength": 1
      }
    },
    "evidenceRefs": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": [
          "id",
          "kind",
          "reference",
          "observedAt"
        ],
        "properties": {
          "id": {
            "type": "string",
            "pattern": "^[a-z0-9-]+$"
          },
          "kind": {
            "type": "string",
            "minLength": 1
          },
          "reference": {
            "type": "string",
            "minLength": 1
          },
          "observedAt": {
            "type": "string",
            "minLength": 1
          }
        }
      }
    }
  }
}
