{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://heimgewebe.local/cabinet/schemas/ecosystem-claim.v1.json",
  "title": "Ecosystem Claim v1",
  "description": "A dated, evidence-bearing statement about an ecosystem subject.",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schemaVersion",
    "kind",
    "id",
    "subject",
    "predicate",
    "status",
    "confidence",
    "evidence"
  ],
  "properties": {
    "schemaVersion": {
      "const": 1
    },
    "kind": {
      "const": "ecosystem_claim"
    },
    "id": {
      "type": "string",
      "pattern": "^claim:[A-Za-z0-9._/-]+$"
    },
    "subject": {
      "type": "string",
      "pattern": "^[a-z][a-z0-9_-]*:[A-Za-z0-9._/-]+$"
    },
    "predicate": {
      "type": "string",
      "minLength": 1
    },
    "object": {
      "type": [
        "string",
        "number",
        "boolean",
        "null"
      ]
    },
    "status": {
      "enum": [
        "observed",
        "plausible",
        "evidenced",
        "validated",
        "canonical",
        "stale",
        "contradicted",
        "refuted"
      ]
    },
    "confidence": {
      "type": "number",
      "minimum": 0,
      "maximum": 1
    },
    "risk": {
      "enum": [
        "none",
        "low",
        "medium",
        "high",
        "critical",
        "unknown"
      ]
    },
    "evidence": {
      "type": "array",
      "items": {
        "$ref": "#/$defs/sourceRef"
      },
      "minItems": 1
    },
    "contradicts": {
      "type": "array",
      "items": {
        "type": "string",
        "pattern": "^claim:[A-Za-z0-9._/-]+$"
      },
      "uniqueItems": true,
      "default": []
    },
    "freshness": {
      "$ref": "#/$defs/freshness"
    },
    "expiresAt": {
      "type": "string",
      "format": "date-time"
    },
    "notes": {
      "type": "string"
    }
  },
  "$defs": {
    "sourceRef": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "type",
        "ref"
      ],
      "properties": {
        "type": {
          "enum": [
            "git",
            "github",
            "ci",
            "runtime",
            "contract",
            "cabinet",
            "manual",
            "dump"
          ]
        },
        "ref": {
          "type": "string",
          "minLength": 1
        },
        "observedAt": {
          "type": "string",
          "format": "date-time"
        },
        "sha256": {
          "type": "string",
          "pattern": "^[a-f0-9]{64}$"
        }
      }
    },
    "freshness": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "class"
      ],
      "properties": {
        "class": {
          "enum": [
            "live",
            "recent_snapshot",
            "dated_snapshot",
            "stale",
            "unknown"
          ]
        },
        "observedAt": {
          "type": "string",
          "format": "date-time"
        },
        "expiresAt": {
          "type": "string",
          "format": "date-time"
        }
      }
    }
  }
}
