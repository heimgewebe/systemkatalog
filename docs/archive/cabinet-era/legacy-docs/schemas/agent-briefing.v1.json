{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://heimgewebe.local/cabinet/schemas/agent-briefing.v1.json",
  "title": "Agent Briefing v1",
  "description": "A reproducible briefing for a delegated agent run.",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schemaVersion",
    "kind",
    "id",
    "taskId",
    "agentProfile",
    "goal",
    "allowedScope",
    "forbiddenChanges",
    "acceptanceTests",
    "evidenceRequired",
    "outputContract"
  ],
  "properties": {
    "schemaVersion": {
      "const": 1
    },
    "kind": {
      "const": "agent_briefing"
    },
    "id": {
      "type": "string",
      "pattern": "^briefing:[A-Za-z0-9._/-]+$"
    },
    "taskId": {
      "type": "string",
      "pattern": "^[A-Z]{2,10}-[A-Z0-9-]+$"
    },
    "agentProfile": {
      "enum": [
        "jules",
        "codex",
        "claude",
        "local_agent",
        "chatgpt",
        "bureau",
        "manual"
      ]
    },
    "goal": {
      "type": "string",
      "minLength": 1
    },
    "contextPaths": {
      "type": "array",
      "items": {
        "type": "string",
        "minLength": 1
      },
      "default": []
    },
    "allowedScope": {
      "type": "array",
      "items": {
        "type": "string",
        "minLength": 1
      },
      "minItems": 1
    },
    "forbiddenChanges": {
      "type": "array",
      "items": {
        "type": "string",
        "minLength": 1
      },
      "minItems": 1
    },
    "acceptanceTests": {
      "type": "array",
      "items": {
        "type": "string",
        "minLength": 1
      },
      "minItems": 1
    },
    "evidenceRequired": {
      "type": "array",
      "items": {
        "type": "string",
        "minLength": 1
      },
      "minItems": 1
    },
    "knownTraps": {
      "type": "array",
      "items": {
        "type": "string",
        "minLength": 1
      },
      "default": []
    },
    "rollbackRequired": {
      "type": "boolean",
      "default": true
    },
    "outputContract": {
      "type": "string",
      "minLength": 1
    },
    "sources": {
      "type": "array",
      "items": {
        "$ref": "#/$defs/sourceRef"
      },
      "default": []
    },
    "createdAt": {
      "type": "string",
      "format": "date-time"
    }
  },
  "$defs": {
    "sourceRef": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "type",
        "ref"
      ],
      "properties": {
        "type": {
          "enum": [
            "git",
            "github",
            "ci",
            "runtime",
            "contract",
            "cabinet",
            "manual",
            "dump"
          ]
        },
        "ref": {
          "type": "string",
          "minLength": 1
        },
        "observedAt": {
          "type": "string",
          "format": "date-time"
        },
        "sha256": {
          "type": "string",
          "pattern": "^[a-f0-9]{64}$"
        }
      }
    },
    "freshness": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "class"
      ],
      "properties": {
        "class": {
          "enum": [
            "live",
            "recent_snapshot",
            "dated_snapshot",
            "stale",
            "unknown"
          ]
        },
        "observedAt": {
          "type": "string",
          "format": "date-time"
        },
        "expiresAt": {
          "type": "string",
          "format": "date-time"
        }
      }
    }
  }
}
