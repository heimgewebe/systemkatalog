{
  "schema": "heimgewebe.system-catalog-runtime.v1",
  "runtime_version": "1",
  "repository_root": "~/repos/cabinet",
  "service": {
    "name": "heimgewebe-systemkatalog.service",
    "compatibility_alias": "cabinet.service",
    "template": "ops/systemd/heimgewebe-systemkatalog.service.tmpl",
    "destination": "~/.config/systemd/user/heimgewebe-systemkatalog.service",
    "bind": "127.0.0.1",
    "port": 4001,
    "mode": "0644"
  },
  "executables": [
    {
      "source": "ops/bin/heimgewebe-systemkatalog",
      "destination": "~/.local/bin/heimgewebe-systemkatalog",
      "mode": "0755"
    },
    {
      "source": "ops/bin/systemkatalogctl",
      "destination": "~/.local/bin/systemkatalogctl",
      "mode": "0755"
    }
  ],
  "retired_runtime_paths": [
    "~/.config/systemd/user/cabinet.service",
    "~/.config/systemd/user/cabinet.service.d/",
    "~/.local/bin/cabinet",
    "~/.local/bin/cabinet-session",
    "~/.local/bin/cabinetctl",
    "~/.local/bin/cabinet-security-gate"
  ],
  "preserved_private_paths": [
    "~/.config/cabinet/",
    "~/.local/state/cabinet/",
    "~/.cabinet/",
    ".cabinet-state/"
  ]
}
