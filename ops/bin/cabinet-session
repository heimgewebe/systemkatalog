#!/usr/bin/env bash
set -euo pipefail
umask 077

TARGET_NOFILE=65536
STATE_DIR="${XDG_STATE_HOME:-$HOME/.local/state}/cabinet"
LOG="$STATE_DIR/cabinet.log"

mkdir -p "$STATE_DIR"
touch "$LOG"
chmod 600 "$LOG"

# Ab hier landen auch frühe Launcherfehler im Cabinet-Log.
exec >>"$LOG" 2>&1

HARD_NOFILE="$(ulimit -Hn)"

if [[ "$HARD_NOFILE" != "unlimited" ]] &&
   (( HARD_NOFILE < TARGET_NOFILE )); then
  echo "STOP: Hard-Limit $HARD_NOFILE liegt unter $TARGET_NOFILE."
  exit 2
fi

ulimit -Sn "$TARGET_NOFILE"

if [[ "$(ulimit -Sn)" != "$TARGET_NOFILE" ]]; then
  echo "STOP: nofile konnte nicht auf $TARGET_NOFILE gesetzt werden."
  exit 3
fi

export NEXT_TELEMETRY_DISABLED=1

echo
echo "=================================================="
echo "Cabinet-Start: $(date --iso-8601=seconds)"
echo "nofile soft:  $(ulimit -Sn)"
echo "nofile hard:  $(ulimit -Hn)"
echo "inotify:      $(sysctl -n fs.inotify.max_user_instances)"
echo "=================================================="

exec "$HOME/.local/bin/cabinet" --no-open
