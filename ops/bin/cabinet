#!/usr/bin/env bash
set -euo pipefail

export PATH="$HOME/.npm-global/bin:$HOME/.local/bin:$HOME/bin:$PATH"

ENV_FILE="${XDG_CONFIG_HOME:-$HOME/.config}/cabinet/runtime.env"
CLI="$HOME/.local/share/cabinet/cabinetai-0.4.4/dist/index.js"

if [[ ! -r "$ENV_FILE" ]]; then
  echo "STOP: Cabinet-Konfiguration fehlt: $ENV_FILE"
  exit 2
fi

if [[ ! -f "$CLI" ]]; then
  echo "STOP: Gepinnte Cabinet-CLI fehlt: $CLI"
  exit 3
fi

set -a
# shellcheck disable=SC1090
. "$ENV_FILE"
set +a

cd "$HOME/repos/cabinet"

exec /usr/bin/node "$CLI" run "$@"
