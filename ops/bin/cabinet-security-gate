#!/usr/bin/env bash
set -euo pipefail

CLI="$HOME/.local/share/cabinet/cabinetai-0.4.4/dist/index.js"
DAEMON="$HOME/.cabinet/app/v0.4.4/server/cabinet-daemon.ts"
WRAPPER="$HOME/.local/bin/cabinet"

test -f "$CLI" || {
  echo "STOP: Gepinnte Cabinet-CLI fehlt."
  exit 20
}

test -f "$DAEMON" || {
  echo "STOP: Cabinet-Daemonquelle fehlt."
  exit 21
}

grep -Fq \
  '[nextBin, "dev", "-H", "127.0.0.1", "-p", String(appPort)]' \
  "$CLI" || {
    echo "STOP: Next.js ist nicht mehr auf Loopback gepinnt."
    exit 22
  }

grep -Fq \
  'server.listen(PORT, "127.0.0.1", () => {' \
  "$DAEMON" || {
    echo "STOP: Daemon ist nicht mehr auf Loopback gepinnt."
    exit 23
  }

grep -Fq \
  '.local/share/cabinet/cabinetai-0.4.4/dist/index.js' \
  "$WRAPPER" || {
    echo "STOP: Cabinet-Wrapper verwendet nicht die gepinnte CLI."
    exit 24
  }
